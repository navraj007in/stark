fn main() {
    let mut i = 0;
    let mut sum = 0;
    while i < 10 {
        i = i + 1;
        if i % 2 == 0 {
            continue;
        }
        sum = sum + i;
    }
    println(sum);

    let mut count = 0;
    loop {
        count = count + 1;
        if count == 5 {
            break;
        }
    }
    println(count);

    for value in 0..5 {
        println(value);
    }
}
