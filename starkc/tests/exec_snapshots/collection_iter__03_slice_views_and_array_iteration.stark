struct Tagged { id: Int32 }

impl Drop for Tagged {
    fn drop(&mut self) {
        println(self.id);
    }
}

fn total(values: &[Int32]) -> Int32 {
    let mut sum = 0;
    let mut index = 0;
    while index < values.len() {
        sum = sum + values[index];
        index = index + 1;
    }
    sum
}

fn scale(values: &mut [Int32]) {
    values[0] = values[0] * 10;
}

fn main() {
    let mut numbers = [1, 2, 3, 4, 5];

    {
        let shared = &numbers[1..4];
        println(shared.len());
        println(shared[0]);
        println(total(shared));
        let inner = &shared[1..3];
        println(inner[0]);
    }

    {
        scale(&mut numbers[2..5]);
    }
    println(numbers[2]);

    {
        let exclusive = &mut numbers[0..2];
        exclusive[1] = 99;
        println(exclusive.len());
    }
    println(numbers[1]);

    let mut running = 0;
    for value in numbers {
        running = running + value;
    }
    println(running);

    let tagged = Some([Tagged { id: 1 }, Tagged { id: 2 }, Tagged { id: 3 }]);
    match tagged {
        Some([first, _, third]) => {
            println(first.id);
            println(third.id);
        }
        None => {
            println(0);
        }
    }
    println(500);

    let mut collected: Vec<Int32> = Vec::new();
    collected.push(7);
    collected.push(8);
    {
        let borrowed = &mut collected[0..2];
        borrowed[0] = 70;
    }
    println(collected[0]);
}
