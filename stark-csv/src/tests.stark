// =================================================================== §19.5: unequal widths ==

fn test_parse_one_field_then_three() {
    let mut expected = Vec::new();
    let mut r0 = Vec::new();
    r0.push(String::from("a"));
    expected.push(r0);
    let mut r1 = Vec::new();
    r1.push(String::from("b"));
    r1.push(String::from("c"));
    r1.push(String::from("d"));
    expected.push(r1);
    expect_parse_ok("a\nb,c,d", &expected, "one field then three");
}

fn test_parse_three_fields_then_one() {
    let mut expected = Vec::new();
    let mut r0 = Vec::new();
    r0.push(String::from("a"));
    r0.push(String::from("b"));
    r0.push(String::from("c"));
    expected.push(r0);
    let mut r1 = Vec::new();
    r1.push(String::from("d"));
    expected.push(r1);
    expect_parse_ok("a,b,c\nd", &expected, "three then one");
}

fn test_parse_blank_record_between_nonblank() {
    let mut expected = Vec::new();
    let mut r0 = Vec::new();
    r0.push(String::from("a"));
    expected.push(r0);
    let mut r1 = Vec::new();
    r1.push(String::from(""));
    expected.push(r1);
    let mut r2 = Vec::new();
    r2.push(String::from("b"));
    expected.push(r2);
    expect_parse_ok("a\n\nb", &expected, "blank record between nonblank");
}

// ===================================================================== §19.6: quote errors ==

fn test_parse_quote_in_unquoted_field() {
    match parse("a\"b") {
        Err(CsvError::QuoteInUnquotedField(offset, record, field)) => {
            if offset != 1u64 || record != 0u64 || field != 0u64 {
                panic("a\"b: wrong QuoteInUnquotedField payload");
            }
        }
        _ => panic("a\"b: expected QuoteInUnquotedField"),
    }
}

fn test_parse_quote_in_unquoted_field_leading_space() {
    match parse(" \"a\"") {
        Err(CsvError::QuoteInUnquotedField(offset, record, field)) => {
            if offset != 1u64 || record != 0u64 || field != 0u64 {
                panic(" \"a\": wrong QuoteInUnquotedField payload");
            }
        }
        _ => panic(" \"a\": expected QuoteInUnquotedField"),
    }
}

fn test_parse_quote_in_unquoted_field_second_field() {
    match parse("a,b\"c") {
        Err(CsvError::QuoteInUnquotedField(offset, record, field)) => {
            if offset != 3u64 || record != 0u64 || field != 1u64 {
                panic("a,b\"c: wrong QuoteInUnquotedField payload");
            }
        }
        _ => panic("a,b\"c: expected QuoteInUnquotedField"),
    }
}

// ================================================================== §19.7: post-quote errors ==

fn test_parse_unexpected_after_closing_quote_letter() {
    match parse("\"a\"b") {
        Err(CsvError::UnexpectedAfterClosingQuote(offset, record, field, byte)) => {
            if offset != 3u64 || record != 0u64 || field != 0u64 || byte != 98u8 {
                panic("\"a\"b: wrong UnexpectedAfterClosingQuote payload");
            }
        }
        _ => panic("\"a\"b: expected UnexpectedAfterClosingQuote"),
    }
}

fn test_parse_unexpected_after_closing_quote_space() {
    match parse("\"a\" ") {
        Err(CsvError::UnexpectedAfterClosingQuote(offset, record, field, byte)) => {
            if offset != 3u64 || record != 0u64 || field != 0u64 || byte != 32u8 {
                panic("\"a\" : wrong UnexpectedAfterClosingQuote payload");
            }
        }
        _ => panic("\"a\" : expected UnexpectedAfterClosingQuote"),
    }
}

fn test_parse_unexpected_after_closing_quote_tab() {
    match parse("\"a\"\t") {
        Err(CsvError::UnexpectedAfterClosingQuote(offset, record, field, byte)) => {
            if offset != 3u64 || record != 0u64 || field != 0u64 || byte != 9u8 {
                panic("\"a\"\\t: wrong UnexpectedAfterClosingQuote payload");
            }
        }
        _ => panic("\"a\"\\t: expected UnexpectedAfterClosingQuote"),
    }
}

fn test_parse_unexpected_after_closing_quote_after_escaped_quote() {
    match parse("\"a\"\"b\"x") {
        Err(CsvError::UnexpectedAfterClosingQuote(offset, record, field, byte)) => {
            if offset != 6u64 || record != 0u64 || field != 0u64 || byte != 120u8 {
                panic("\"a\"\"b\"x: wrong UnexpectedAfterClosingQuote payload");
            }
        }
        _ => panic("\"a\"\"b\"x: expected UnexpectedAfterClosingQuote"),
    }
}

