                panic("a,\"b: wrong UnterminatedQuotedField payload");
            }
        }
        _ => panic("a,\"b: expected UnterminatedQuotedField"),
    }
}

fn test_parse_unterminated_after_escaped_quote() {
    match parse("\"a\"\"") {
        Err(CsvError::UnterminatedQuotedField(offset, record, field)) => {
            if offset != 0u64 || record != 0u64 || field != 0u64 {
                panic("\"a\"\": wrong UnterminatedQuotedField payload");
            }
        }
        _ => panic("\"a\"\": expected UnterminatedQuotedField"),
    }
}

// =================================================================== §19.10: limits ==

fn test_limit_input_bytes_boundary_and_excess() {
    let l = limits(3u64, 100u64, 100u64, 1000u64, 1000u64, 1000u64);
    match parse_with_limits("abc", &l) {
        Ok(_) => {}
        Err(_) => panic("exact input-byte boundary must succeed"),
    }
    match parse_with_limits("abcd", &l) {
        Err(CsvError::InputTooLarge(actual, limit)) => {
            if actual != 4u64 || limit != 3u64 {
                panic("wrong InputTooLarge payload");
            }
        }
        _ => panic("first excess byte must return InputTooLarge"),
    }
}

fn test_limit_records_boundary_and_excess() {
    let l = limits(1000u64, 2u64, 100u64, 1000u64, 1000u64, 1000u64);
    match parse_with_limits("a\nb", &l) {
        Ok(_) => {}
        Err(_) => panic("exact record-count boundary must succeed"),
    }
    match parse_with_limits("a\nb\nc", &l) {
        Err(CsvError::TooManyRecords(attempted, limit)) => {
            if attempted != 3u64 || limit != 2u64 {
                panic("wrong TooManyRecords payload");
            }
        }
        _ => panic("first excess record must return TooManyRecords"),
    }
}

fn test_limit_fields_per_record_boundary_and_excess() {
    let l = limits(1000u64, 100u64, 2u64, 1000u64, 1000u64, 1000u64);
    match parse_with_limits("a,b", &l) {
        Ok(_) => {}
        Err(_) => panic("exact fields-per-record boundary must succeed"),
    }
    match parse_with_limits("a,b,c", &l) {
        Err(CsvError::TooManyFields(record, attempted, limit)) => {
            if record != 0u64 || attempted != 3u64 || limit != 2u64 {
                panic("wrong TooManyFields payload");
            }
        }
        _ => panic("first excess field must return TooManyFields"),
    }
}

fn test_limit_total_fields_boundary_and_excess() {
    let l = limits(1000u64, 100u64, 100u64, 3u64, 1000u64, 1000u64);
    match parse_with_limits("a,b\nc", &l) {
        Ok(_) => {}
        Err(_) => panic("exact total-fields boundary must succeed"),
    }
    match parse_with_limits("a,b\nc,d", &l) {
        Err(CsvError::TooManyTotalFields(attempted, limit)) => {
            if attempted != 4u64 || limit != 3u64 {
                panic("wrong TooManyTotalFields payload");
            }
        }
        _ => panic("first excess total field must return TooManyTotalFields"),
    }
}

fn test_limit_field_bytes_ascii_boundary_and_excess() {
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 3u64, 1000u64);
    match parse_with_limits("abc", &l) {
        Ok(_) => {}
        Err(_) => panic("exact ASCII field-byte boundary must succeed"),
    }
    match parse_with_limits("abcd", &l) {
        Err(CsvError::FieldTooLarge(record, field, attempted, limit)) => {
            if record != 0u64 || field != 0u64 || attempted != 4u64 || limit != 3u64 {
                panic("wrong FieldTooLarge payload (ASCII)");
            }
        }
        _ => panic("first excess ASCII field byte must return FieldTooLarge"),
    }
}

fn test_limit_field_bytes_multibyte_boundary_and_excess() {
    // "中" is 3 UTF-8 bytes.
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 3u64, 1000u64);
    match parse_with_limits("中", &l) {
        Ok(_) => {}
        Err(_) => panic("exact multibyte field-byte boundary must succeed"),
    }
    match parse_with_limits("中a", &l) {
        Err(CsvError::FieldTooLarge(record, field, attempted, limit)) => {
            if record != 0u64 || field != 0u64 || attempted != 4u64 || limit != 3u64 {
                panic("wrong FieldTooLarge payload (multibyte)");
            }
        }
        _ => panic("first excess multibyte field byte must return FieldTooLarge"),
    }
}

fn test_limit_output_bytes_boundary_and_excess() {
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 3u64);
    match write_with_limits(&one_row1("abc"), &l) {
        Ok(_) => {}
        Err(_) => panic("exact output-byte boundary must succeed"),
    }
    match write_with_limits(&one_row1("abcd"), &l) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 4u64 || limit != 3u64 {
                panic("wrong OutputTooLarge payload");
            }
        }
        _ => panic("first excess output byte must return OutputTooLarge"),
    }
}

// ================================================================ §19.11: state reset ==

fn test_parse_failed_then_successful() {
    match parse("a\"b") {
        Ok(_) => panic("a\"b must fail"),
        Err(_) => {}
    }
    expect_parse_ok("a,b", &one_row2("a", "b"), "successful parse after a failed one");
}

fn test_parse_repeated_successful() {
    expect_parse_ok("a", &one_row1("a"), "repeat 1");
    expect_parse_ok("b", &one_row1("b"), "repeat 2");
    expect_parse_ok("c", &one_row1("c"), "repeat 3");
}

// =================================================================== §20: writer -- basic ==

fn test_write_zero_records() {
    match write(&Vec::new()) {
        Ok(s) => {
            if s.as_str() != "" {
                panic("zero records must write to empty string");
            }
        }
        Err(_) => panic("zero records must not error"),
    }
}

