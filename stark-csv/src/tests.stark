}

// ============================================================================ §20: limits ==

fn test_write_limit_field_content_excess() {
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 2u64);
    match write_with_limits(&one_row1("ab"), &l) {
        Ok(_) => {}
        Err(_) => panic("exact field-content boundary must succeed"),
    }
    match write_with_limits(&one_row1("abc"), &l) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 3u64 || limit != 2u64 {
                panic("wrong OutputTooLarge payload (field content)");
            }
        }
        _ => panic("field-content excess must return OutputTooLarge"),
    }
}

fn test_write_limit_comma_excess() {
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 2u64);
    match write_with_limits(&one_row2("a", "b"), &l) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 3u64 || limit != 2u64 {
                panic("wrong OutputTooLarge payload (comma)");
            }
        }
        _ => panic("comma-caused excess must return OutputTooLarge"),
    }
}

fn test_write_limit_crlf_excess() {
    let mut rows = Vec::new();
    let mut r0 = Vec::new();
    r0.push(String::from("a"));
    rows.push(r0);
    let mut r1 = Vec::new();
    r1.push(String::from("b"));
    rows.push(r1);
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 2u64);
    match write_with_limits(&rows, &l) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 3u64 || limit != 2u64 {
                panic("wrong OutputTooLarge payload (CRLF)");
            }
        }
        _ => panic("CRLF-caused excess must return OutputTooLarge"),
    }
}

fn test_write_limit_quote_excess() {
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 2u64);
    match write_with_limits(&one_row1("a,"), &l) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 3u64 || limit != 2u64 {
                panic("wrong OutputTooLarge payload (opening quote)");
            }
        }
        _ => panic("opening-quote excess must return OutputTooLarge"),
    }
}

fn test_write_limit_quote_doubling_excess() {
    // field = `"` requires quoting: opening quote (1) + doubled quote (2) + closing quote (1) = 4
    // bytes total.
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 4u64);
    match write_with_limits(&one_row1("\""), &l) {
        Ok(_) => {}
        Err(_) => panic("exact boundary for a doubled-quote field must succeed"),
    }
    let tight = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 3u64);
    match write_with_limits(&one_row1("\""), &tight) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 4u64 || limit != 3u64 {
                panic("wrong OutputTooLarge payload (quote doubling)");
            }
        }
        _ => panic("quote-doubling excess must return OutputTooLarge"),
    }
}

fn test_write_limit_multibyte_utf8_excess() {
    // "中" is 3 bytes.
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 3u64);
    match write_with_limits(&one_row1("中"), &l) {
        Ok(_) => {}
        Err(_) => panic("exact multibyte boundary must succeed"),
    }
    let tight = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 2u64);
    match write_with_limits(&one_row1("中"), &tight) {
        Err(CsvError::OutputTooLarge(attempted, limit)) => {
            if attempted != 3u64 || limit != 2u64 {
                panic("wrong OutputTooLarge payload (multibyte)");
            }
        }
        _ => panic("multibyte excess must return OutputTooLarge"),
    }
}

// ======================================================================= §20: input immutability ==

fn test_write_input_unchanged_after_success() {
    let rows = one_row2("a", "b");
    let _ = write(&rows);
    if rows.len() != 1u64 || rows[0u64].len() != 2u64 || rows[0u64][0u64].as_str() != "a" {
        panic("records must be unchanged after a successful write");
    }
}

fn test_write_input_unchanged_after_failure() {
    let rows = one_row1("abc");
    let l = limits(1000u64, 100u64, 100u64, 1000u64, 1000u64, 1u64);
    let _ = write_with_limits(&rows, &l);
    if rows.len() != 1u64 || rows[0u64][0u64].as_str() != "abc" {
        panic("records must be unchanged after a failed write");
    }
}

// ==================================================================== §18: canonicalization ==

fn test_canonicalization_write_then_parse_round_trips() {
    let rows = one_row1("a");
    match write(&rows) {
        Ok(s) => {
            match parse(s.as_str()) {
                Ok(back) => assert_rows_eq(&back, &rows, "parse(write(records)) != records"),
                Err(_) => panic("re-parsing written output must succeed"),
            }
        }
        Err(_) => panic("write must succeed"),
    }
}

fn test_canonicalization_examples() {
    match parse("a\nb\n") {
        Ok(rows) => match write(&rows) {
            Ok(s) => {
                if s.as_str() != "a\r\nb" {
                    panic("\"a\\nb\\n\" -> \"a\\r\\nb\" example failed");
                }
            }
            Err(_) => panic("write must succeed"),
        }
        Err(_) => panic("parse must succeed"),
    }

    match parse("\"a\"") {
        Ok(rows) => match write(&rows) {
            Ok(s) => {
                if s.as_str() != "a" {
                    panic("\"\\\"a\\\"\" -> \"a\" example failed");
                }
            }
            Err(_) => panic("write must succeed"),
        }
        Err(_) => panic("parse must succeed"),
    }

    match parse("\"a,b\"") {
        Ok(rows) => match write(&rows) {
            Ok(s) => {
                if s.as_str() != "\"a,b\"" {
                    panic("\"\\\"a,b\\\"\" -> \"\\\"a,b\\\"\" example failed");
                }
            }
            Err(_) => panic("write must succeed"),
        }
        Err(_) => panic("parse must succeed"),
    }

    match parse("\"a\"\"b\"") {
        Ok(rows) => match write(&rows) {
            Ok(s) => {
                if s.as_str() != "\"a\"\"b\"" {
                    panic("\"\\\"a\\\"\\\"b\\\"\" -> \"\\\"a\\\"\\\"b\\\"\" example failed");
                }
            }
            Err(_) => panic("write must succeed"),
        }
        Err(_) => panic("parse must succeed"),
    }
}

// ========================================================================= §21: round trip ==

fn round_trip_one(field_char: Char, field_len: UInt64) {
    // A record consisting of exactly one empty field (field_len == 0) writes to "", which is
    // indistinguishable on the wire from a zero-field record and from a wholly empty document
    // (§12: "" -> [], §17.5's own documented normalization exception). A second, fixed,
    // non-empty sentinel field keeps the record's on-wire representation non-empty for every
    // boundary length -- including 0 -- so this test exercises the field-byte-length boundary
    // this section actually cares about, not that unrelated, structurally-unavoidable ambiguity.
    let mut field = String::new();
    let mut i: UInt64 = 0u64;
    while i < field_len {
        field.push(field_char);
        i = i + 1u64;
    }
    let mut row = Vec::new();
    row.push(field);
    row.push(String::from("sentinel"));
    let mut rows = Vec::new();
    rows.push(row);

    match write(&rows) {
        Ok(s) => match parse(s.as_str()) {
            Ok(back) => assert_rows_eq(&back, &rows, "round trip mismatch at a boundary length"),
            Err(_) => panic("round-trip parse must succeed"),
        }
        Err(_) => panic("round-trip write must succeed"),
    }
}

fn test_round_trip_boundary_field_lengths() {
    round_trip_one('x', 0u64);
    round_trip_one('x', 1u64);
    round_trip_one('x', 2u64);
    round_trip_one('x', 15u64);
    round_trip_one('x', 16u64);
    round_trip_one('x', 17u64);
    round_trip_one('x', 255u64);
    round_trip_one('x', 256u64);
    round_trip_one('x', 257u64);
    round_trip_one('x', 1023u64);
    round_trip_one('x', 1024u64);
    round_trip_one('x', 1025u64);
}

fn test_round_trip_record_counts() {
    let mut counts: Vec<UInt64> = Vec::new();
    counts.push(0u64);
    counts.push(1u64);
    counts.push(2u64);
    counts.push(3u64);
    counts.push(10u64);
    counts.push(100u64);
    let mut c: UInt64 = 0u64;
    while c < counts.len() {
        let n = counts[c];
        let mut rows = Vec::new();
        let mut r: UInt64 = 0u64;
        while r < n {
            let mut row = Vec::new();
            row.push(String::from("x"));
            rows.push(row);
            r = r + 1u64;
        }
        match write(&rows) {
            Ok(s) => match parse(s.as_str()) {
                Ok(back) => assert_rows_eq(&back, &rows, "round trip mismatch at a record count"),
                Err(_) => panic("round-trip parse must succeed"),
            }
            Err(_) => panic("round-trip write must succeed"),
        }
        c = c + 1u64;
    }
}

fn test_round_trip_field_counts() {
    let mut counts: Vec<UInt64> = Vec::new();
    counts.push(1u64);
    counts.push(2u64);
    counts.push(3u64);
    counts.push(10u64);
    let mut c: UInt64 = 0u64;
    while c < counts.len() {
        let n = counts[c];
        let mut row = Vec::new();
        let mut f: UInt64 = 0u64;
        while f < n {
            row.push(String::from("x"));
            f = f + 1u64;
        }
        let mut rows = Vec::new();
        rows.push(row);
        match write(&rows) {
            Ok(s) => match parse(s.as_str()) {
                Ok(back) => assert_rows_eq(&back, &rows, "round trip mismatch at a field count"),
                Err(_) => panic("round-trip parse must succeed"),
            }
            Err(_) => panic("round-trip write must succeed"),
        }
        c = c + 1u64;
    }
}

fn test_round_trip_structural_and_unicode_and_nul() {
    let mut rows = Vec::new();
    let mut row = Vec::new();
    row.push(String::from("a,b"));
    row.push(String::from("c\"d"));
    row.push(String::from("e\r\nf"));
    row.push(String::from("中文😀"));
    row.push(String::from("a\u{0}b"));
    rows.push(row);
    match write(&rows) {
        Ok(s) => match parse(s.as_str()) {
            Ok(back) => assert_rows_eq(&back, &rows, "structural/Unicode/NUL round trip mismatch"),
            Err(_) => panic("round-trip parse must succeed"),
        }
        Err(_) => panic("round-trip write must succeed"),
    }
}
