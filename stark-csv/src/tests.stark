use super::default_limits;
use super::limits;
use super::parse;
use super::parse_with_limits;
use super::write;
use super::write_with_limits;
use super::CsvError;

// ============================================================ helpers ==

fn assert_rows_eq(actual: &Vec<Vec<String>>, expected: &Vec<Vec<String>>, msg: &str) {
    if actual.len() != expected.len() {
        panic(msg);
    }
    let mut i: UInt64 = 0u64;
    while i < actual.len() {
        let a = &actual[i];
        let e = &expected[i];
        if a.len() != e.len() {
            panic(msg);
        }
        let mut j: UInt64 = 0u64;
        while j < a.len() {
            if a[j].as_str() != e[j].as_str() {
                panic(msg);
            }
            j = j + 1u64;
        }
        i = i + 1u64;
    }
}

fn one_row1(a: &str) -> Vec<Vec<String>> {
    let mut row = Vec::new();
    row.push(String::from(a));
    let mut rows = Vec::new();
    rows.push(row);
    rows
}

fn one_row2(a: &str, b: &str) -> Vec<Vec<String>> {
    let mut row = Vec::new();
    row.push(String::from(a));
    row.push(String::from(b));
    let mut rows = Vec::new();
    rows.push(row);
    rows
}

fn one_row3(a: &str, b: &str, c: &str) -> Vec<Vec<String>> {
    let mut row = Vec::new();
    row.push(String::from(a));
    row.push(String::from(b));
    row.push(String::from(c));
    let mut rows = Vec::new();
    rows.push(row);
    rows
}

fn expect_parse_ok(input: &str, expected: &Vec<Vec<String>>, msg: &str) {
    match parse(input) {
        Ok(rows) => assert_rows_eq(&rows, expected, msg),
        Err(_) => panic(msg),
    }
}

// ================================================================ §19.1: basic and separators ==

fn test_parse_empty_input() {
    match parse("") {
        Ok(rows) => {
            if rows.len() != 0u64 {
                panic("empty input must parse to zero records");
            }
        }
        Err(_) => panic("empty input must parse"),
    }
}

fn test_parse_one_field() {
    let mut expected = Vec::new();
    let mut row = Vec::new();
    row.push(String::from("a"));
    expected.push(row);
    expect_parse_ok("a", &expected, "one field");
}

fn test_parse_two_fields() {
    let mut expected = Vec::new();
    let mut row = Vec::new();
    row.push(String::from("a"));
    row.push(String::from("b"));
    expected.push(row);
    expect_parse_ok("a,b", &expected, "two fields");
}

fn test_parse_three_fields() {
    let mut expected = Vec::new();
    let mut row = Vec::new();
    row.push(String::from("a"));
    row.push(String::from("b"));
    row.push(String::from("c"));
    expected.push(row);
    expect_parse_ok("a,b,c", &expected, "three fields");
}

fn test_parse_two_records() {
    let mut expected = Vec::new();
    let mut r0 = Vec::new();
    r0.push(String::from("a"));
    expected.push(r0);
    let mut r1 = Vec::new();
    r1.push(String::from("b"));
    expected.push(r1);
    expect_parse_ok("a\nb", &expected, "two records (LF)");
}

fn test_parse_lf_separator() {
    let mut expected = Vec::new();
    let mut r0 = Vec::new();
