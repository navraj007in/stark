// ================================================================= §19.3: quoted fields ==

fn test_parse_quoted_ordinary_field() {
    expect_parse_ok("\"abc\"", &one_row1("abc"), "quoted ordinary field");
}

fn test_parse_quoted_empty_field() {
    expect_parse_ok("\"\"", &one_row1(""), "quoted empty field");
}

fn test_parse_quoted_comma() {
    expect_parse_ok("\"a,b\"", &one_row1("a,b"), "quoted comma");
}

fn test_parse_quoted_lf() {
    expect_parse_ok("\"a\nb\"", &one_row1("a\nb"), "quoted LF");
}

fn test_parse_quoted_cr() {
    expect_parse_ok("\"a\rb\"", &one_row1("a\rb"), "quoted CR");
}

fn test_parse_quoted_crlf() {
    expect_parse_ok("\"a\r\nb\"", &one_row1("a\r\nb"), "quoted CRLF");
}

fn test_parse_quoted_leading_trailing_spaces() {
    expect_parse_ok("\"  a  \"", &one_row1("  a  "), "quoted leading/trailing spaces");
}

fn test_parse_quoted_tab() {
    expect_parse_ok("\"a\tb\"", &one_row1("a\tb"), "quoted tab");
}

fn test_parse_quoted_nul() {
    expect_parse_ok("\"a\u{0}b\"", &one_row1("a\u{0}b"), "quoted NUL");
}

fn test_parse_one_escaped_quote() {
    expect_parse_ok("\"a\"\"b\"", &one_row1("a\"b"), "one escaped quote");
}

fn test_parse_several_escaped_quotes() {
    expect_parse_ok("\"\"\"a\"\"\"", &one_row1("\"a\""), "several escaped quotes");
}

fn test_parse_escaped_quote_beside_comma() {
    expect_parse_ok("\"a\"\",b\"", &one_row1("a\",b"), "escaped quote beside comma");
}

fn test_parse_escaped_quote_beside_newline() {
    expect_parse_ok("\"a\"\"\nb\"", &one_row1("a\"\nb"), "escaped quote beside newline");
}

