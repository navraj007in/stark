// ================================================================== §19.2: empty cases ==

fn test_parse_empty_string_is_zero_records() {
    expect_parse_ok("", &Vec::new(), "\"\" -> []");
}

fn test_parse_bare_lf_is_one_blank_record() {
    let mut expected = Vec::new();
    let mut r0 = Vec::new();
    r0.push(String::from(""));
    expected.push(r0);
    expect_parse_ok("\n", &expected, "\"\\n\" -> [[\"\"]]");
}

fn test_parse_bare_crlf_is_one_blank_record() {
    let mut expected = Vec::new();
