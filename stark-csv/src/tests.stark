    r0.push(String::from("b"));
    expected.push(r0);
    let mut r1 = Vec::new();
    r1.push(String::from("c"));
    r1.push(String::from("d"));
    expected.push(r1);
    expect_parse_ok("a,b\nc,d", &expected, "LF separator");
}

